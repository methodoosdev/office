@model (IList<App.Core.Infrastructure.Dtos.Financial.FinancialObligationDto> List, string Title, string TraderName);
@inject App.Services.Localization.ILocalizationService _localizationService;
@inject App.Services.Helpers.IDateTimeHelper _dateTimeHelper;
@inject App.Services.Common.IPriceFormatter _priceFormatter;

<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta content="text/html; charset=utf-8" http-equiv="Content-Type">
</head>

<body>
    @{
        var i = 0;
    }
    <br>
    <br>
    <table style="width: 100%;border: 1px solid #dedede;border-collapse: collapse;">
        <thead>
            <tr style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                <td colspan="5" style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                    <span style="float: left; font-size: 20px;">@Model.Title</span>
                    <span style="float:right;">@((await _dateTimeHelper.ConvertToUserTimeAsync(DateTime.Now)).ToString("dd/MM/yyyy"))</span>
                </td>
            </tr>
            <tr style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                <td colspan="5" style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                    <div style="font-size: 20px;color:#FF5722;">@Model.TraderName</div>
                </td>
            </tr>

            <tr style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                <th style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _localizationService.GetResourceAsync("App.Models.FinancialObligationModel.Columns.Institution"))</th>
                <th style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _localizationService.GetResourceAsync("App.Models.FinancialObligationModel.Columns.PaymentType"))</th>
                <th style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _localizationService.GetResourceAsync("App.Models.FinancialObligationModel.Columns.PaymentValue"))</th>
                <th style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _localizationService.GetResourceAsync("App.Models.FinancialObligationModel.Columns.PaymentIdentity"))</th>
                <th style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _localizationService.GetResourceAsync("App.Models.FinancialObligationModel.Columns.PaymentDate"))</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.List)
            {<tr style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">
                    <td style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@item.Institution</td>
                    <td style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@item.PaymentType</td>
                    <td style="text-align:right;border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@(await _priceFormatter.FormatDecimalAsync(item.PaymentValue))</td>
                    <td style="border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@item.PaymentIdentity</td>
                    <td style="text-align:center;border: 1px solid #dedede;border-collapse: collapse;padding: 5px;">@((await _dateTimeHelper.ConvertToUserTimeAsync(item.PaymentDate)).ToString("dd/MM/yyyy"))</td>
            </tr>
             if (Model.List.Count() - 1 > i)
            {
                <span style="display:block; clear:both; page-break-after:always;"></span>
            }
            i++;
            }
        </tbody>
    </table>
    <br>
    <br>
    <br>
    <br>
    <br>
    <div style="text-align:center;">
        <img src="data:image/jpeg;base64," />
    </div>
</body>
</html>