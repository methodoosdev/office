{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "client": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss",
                    "standalone": false
                },
                "@schematics/angular:directive": {
                    "standalone": false
                },
                "@schematics/angular:pipe": {
                    "standalone": false
                }
            },
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:browser",
                    "options": {
                        "outputPath": "../server/App.Web/wwwroot",
                        "index": "src/index.html",
                        "main": "src/main.ts",
                        "allowedCommonJsDependencies": [
                            "exceljs"
                        ],
                        "polyfills": [
                            "web-animations-js",
                            "zone.js",
                            "@angular/localize/init"
                        ],
                        "tsConfig": "tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/pdf-styles.css",
                            "src/styles-kendo-theme.scss",
                            "src/styles.scss"
                        ],
                        "scripts": []
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "4mb",
                                    "maximumError": "5mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "8kb",
                                    "maximumError": "10kb"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "buildOptimizer": false,
                            "optimization": false,
                            "vendorChunk": true,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "namedChunks": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "browserTarget": "client:build:production"
                        },
                        "development": {
                            "browserTarget": "client:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n",
                    "options": {
                        "browserTarget": "client:build"
                    }
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": [
                            "zone.js",
                            "zone.js/testing"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/styles.scss"
                        ],
                        "scripts": []
                    }
                }
            }
        },
        "primeNg": {
          "projectType": "library",
          "root": "projects/prime-ng",
          "sourceRoot": "projects/prime-ng/src",
          "prefix": "lib",
          "architect": {
            "build": {
              "builder": "@angular-devkit/build-angular:ng-packagr",
              "options": {
                "project": "projects/prime-ng/ng-package.json"
              },
              "configurations": {
                "production": {
                  "tsConfig": "projects/prime-ng/tsconfig.lib.prod.json"
                },
                "development": {
                  "tsConfig": "projects/prime-ng/tsconfig.lib.json"
                }
              },
              "defaultConfiguration": "production"
            },
            "test": {
              "builder": "@angular-devkit/build-angular:karma",
              "options": {
                "tsConfig": "projects/prime-ng/tsconfig.spec.json",
                "polyfills": [
                  "zone.js",
                  "zone.js/testing"
                ]
              }
            }
          }
        },
        "jwtNg": {
          "projectType": "library",
          "root": "projects/jwt-ng",
          "sourceRoot": "projects/jwt-ng/src",
          "prefix": "lib",
          "architect": {
            "build": {
              "builder": "@angular-devkit/build-angular:ng-packagr",
              "options": {
                "project": "projects/jwt-ng/ng-package.json"
              },
              "configurations": {
                "production": {
                  "tsConfig": "projects/jwt-ng/tsconfig.lib.prod.json"
                },
                "development": {
                  "tsConfig": "projects/jwt-ng/tsconfig.lib.json"
                }
              },
              "defaultConfiguration": "production"
            },
            "test": {
              "builder": "@angular-devkit/build-angular:karma",
              "options": {
                "tsConfig": "projects/jwt-ng/tsconfig.spec.json",
                "polyfills": [
                  "zone.js",
                  "zone.js/testing"
                ]
              }
            }
          }
        },
        "formlyNg": {
          "projectType": "library",
          "root": "projects/formly-ng",
          "sourceRoot": "projects/formly-ng/src",
          "prefix": "lib",
          "architect": {
            "build": {
              "builder": "@angular-devkit/build-angular:ng-packagr",
              "options": {
                "project": "projects/formly-ng/ng-package.json"
              },
              "configurations": {
                "production": {
                  "tsConfig": "projects/formly-ng/tsconfig.lib.prod.json"
                },
                "development": {
                  "tsConfig": "projects/formly-ng/tsconfig.lib.json"
                }
              },
              "defaultConfiguration": "production"
            },
            "test": {
              "builder": "@angular-devkit/build-angular:karma",
              "options": {
                "tsConfig": "projects/formly-ng/tsconfig.spec.json",
                "polyfills": [
                  "zone.js",
                  "zone.js/testing"
                ]
              }
            }
          }
        },
        "officeNg": {
          "projectType": "library",
          "root": "projects/office-ng",
          "sourceRoot": "projects/office-ng/src",
          "prefix": "lib",
          "architect": {
            "build": {
              "builder": "@angular-devkit/build-angular:ng-packagr",
              "options": {
                "project": "projects/office-ng/ng-package.json"
              },
              "configurations": {
                "production": {
                  "tsConfig": "projects/office-ng/tsconfig.lib.prod.json"
                },
                "development": {
                  "tsConfig": "projects/office-ng/tsconfig.lib.json"
                }
              },
              "defaultConfiguration": "production"
            },
            "test": {
              "builder": "@angular-devkit/build-angular:karma",
              "options": {
                "tsConfig": "projects/office-ng/tsconfig.spec.json",
                "polyfills": [
                  "zone.js",
                  "zone.js/testing"
                ]
              }
            }
          }
        }
    },
    "cli": {
      "analytics": false
    }
}
